<style>
:root {
  --c-bg:        #F5E6D3;
  --c-bg-alt:    #EDDAC4;
  --c-surface:   #FBF4E9;
  --c-text:      #1A1A1A;
  --c-text-mut:  #5C5C5C;
  --c-text-soft: #8A8A8A;
  --c-border:    #DCC9B4;
  --c-primary:   #1F3A2D;
  --c-primary-l: #2E5E3E;
  --c-primary-d: #142420;
  --c-accent:    #C9A961;
  --c-accent-d:  #A8893F;
  --c-cta:       #C5573D;
  --c-cta-d:     #9E4530;
  --c-trust:     #2E7D32;
  --f-zh-serif:  'Noto Serif TC', 'Songti TC', serif;
  --f-zh-sans:   'Noto Sans TC', system-ui, -apple-system, sans-serif;
  --f-en-serif:  'Cormorant Garamond', Georgia, serif;
  --f-en-sans:   'Inter', system-ui, -apple-system, sans-serif;
  --f-num:       'Inter', sans-serif;
  --sp-1: 4px; --sp-2: 8px; --sp-3: 12px; --sp-4: 16px;
  --sp-5: 24px; --sp-6: 32px; --sp-7: 48px; --sp-8: 64px;
  --sp-9: 96px; --sp-10: 128px;
  --w-max: 1200px;
  --w-narrow: 880px;
  --r-sm: 4px; --r-md: 8px; --r-lg: 12px; --r-xl: 24px;
  --shadow-sm: 0 1px 2px rgba(20,36,32,0.04), 0 2px 4px rgba(20,36,32,0.04);
  --shadow-md: 0 4px 12px rgba(20,36,32,0.06), 0 8px 24px rgba(20,36,32,0.04);
  --shadow-lg: 0 8px 24px rgba(20,36,32,0.08), 0 16px 48px rgba(20,36,32,0.06);
  --t-fast: 150ms cubic-bezier(.4,0,.2,1);
  --t-mid:  250ms cubic-bezier(.4,0,.2,1);
  --t-slow: 600ms cubic-bezier(.16,1,.3,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--f-en-sans);
  font-weight: 400;
  font-size: clamp(15px, 1vw + 12px, 17px);
  line-height: 1.7;
  color: var(--c-text);
  background: var(--c-bg);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}
img, svg { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; transition: color var(--t-fast); }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
:focus-visible { outline: 3px solid var(--c-accent); outline-offset: 2px; border-radius: var(--r-sm); }
::selection { background: var(--c-primary); color: white; }

.skip-link { position: absolute; top: -100px; left: 8px; background: var(--c-primary); color: white; padding: var(--sp-3) var(--sp-5); border-radius: var(--r-md); z-index: 1000; transition: top var(--t-fast); }
.skip-link:focus { top: 8px; }

.h1 { font-family: var(--f-en-sans); font-weight: 900; font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.1; letter-spacing: -0.025em; }
.h2 { font-family: var(--f-en-sans); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.2; letter-spacing: -0.02em; }
.h3 { font-family: var(--f-en-sans); font-weight: 700; font-size: clamp(1.125rem, 1.5vw, 1.375rem); line-height: 1.3; }
.eyebrow { font-family: var(--f-en-sans); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--c-accent-d); }
.lede { font-size: clamp(1rem, 1.2vw, 1.125rem); color: var(--c-text-mut); max-width: 60ch; line-height: 1.65; }
.num { font-family: var(--f-num); font-feature-settings: 'tnum' on, 'lnum' on; }

.container { max-width: var(--w-max); margin-inline: auto; padding-inline: clamp(20px, 4vw, 48px); }
.container.narrow { max-width: var(--w-narrow); }
.section { padding-block: clamp(64px, 8vw, 128px); }
.section--alt { background: var(--c-bg-alt); }
.section--dark { background: var(--c-primary); color: var(--c-bg); }
.section--dark .eyebrow { color: var(--c-accent); }
.section--dark .lede { color: rgba(255,255,255,0.78); }

.sec-head { display: flex; flex-direction: column; gap: var(--sp-3); margin-bottom: clamp(40px, 5vw, 64px); }
.sec-head--center { align-items: center; text-align: center; }

[data-reveal] { opacity: 0; transform: translateY(20px); transition: opacity var(--t-slow), transform var(--t-slow); }
[data-reveal].is-visible { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) {
  [data-reveal] { opacity: 1; transform: none; transition: none; }
  html { scroll-behavior: auto; }
}

.topbar { background: var(--c-primary-d); color: rgba(255,255,255,0.78); font-size: 0.75rem; padding: var(--sp-2) 0; }
.topbar__inner { display: flex; justify-content: space-between; align-items: center; gap: var(--sp-5); flex-wrap: wrap; }
.topbar__contact { display: flex; gap: var(--sp-5); }
.topbar__contact a:hover { color: var(--c-accent); }
.lang-switch { display: flex; gap: var(--sp-1); align-items: center; }
.lang-switch a { padding: 2px var(--sp-2); border-radius: var(--r-sm); font-family: var(--f-en-sans); font-weight: 500; letter-spacing: 0.05em; }
.lang-switch a.is-active { background: var(--c-accent); color: var(--c-primary-d); }
.lang-switch a:hover:not(.is-active) { color: var(--c-accent); }
.lang-switch span { opacity: 0.4; }

.header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(245, 230, 211, 0.92);
  backdrop-filter: saturate(160%) blur(12px);
  -webkit-backdrop-filter: saturate(160%) blur(12px);
  border-bottom: 1px solid var(--c-border);
}
.header__inner { display: flex; align-items: center; justify-content: space-between; height: 72px; gap: var(--sp-5); }

.brand { display: flex; align-items: center; gap: 14px; }
.brand__zh {
  font-family: var(--f-zh-sans);
  font-weight: 900;
  font-size: 1.18rem;
  letter-spacing: 0.04em;
  color: var(--c-primary);
  line-height: 1;
  padding-right: 14px;
  border-right: 1px solid var(--c-border);
  display: flex; flex-direction: column; gap: 4px;
}
.brand__zh small {
  font-family: var(--f-en-sans);
  font-size: 0.58rem;
  font-weight: 500;
  color: var(--c-text-soft);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  white-space: nowrap;
}
.brand__en { display: flex; flex-direction: column; gap: 4px; line-height: 1; }
.brand__name {
  font-family: 'Mona Sans', var(--f-en-sans);
  font-weight: 900;
  font-size: 1.85rem;
  letter-spacing: -0.05em;
  color: var(--c-primary);
  line-height: 0.85;
}
.brand__name::after { content:'.'; color: var(--c-accent); }
.brand__tag {
  font-family: 'Mona Sans', var(--f-en-sans);
  font-size: 0.55rem;
  font-weight: 700;
  color: var(--c-text-soft);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  white-space: nowrap;
}

.nav { display: flex; gap: var(--sp-4); align-items: center; }
.nav a { font-size: 0.85rem; font-weight: 500; color: var(--c-text-mut); letter-spacing: 0.02em; }
.nav a:hover { color: var(--c-primary); }
.nav__cta { background: var(--c-cta); color: white !important; padding: var(--sp-3) var(--sp-5); border-radius: var(--r-md); font-weight: 600; transition: all var(--t-fast); }
.nav__cta:hover { background: var(--c-cta-d); transform: translateY(-1px); }
.nav-toggle { display: none; }
@media (max-width: 1180px) {
  .brand__tag, .brand__zh small { display: none; }
  .brand__zh { padding-right: 12px; }
}
@media (max-width: 1000px) {
  .nav { display: none; }
  .nav.is-open {
    display: flex; flex-direction: column;
    position: absolute; top: 100%; left: 0; right: 0;
    background: var(--c-bg); padding: var(--sp-5);
    border-bottom: 1px solid var(--c-border); gap: var(--sp-4);
  }
  .nav-toggle { display: grid; place-items: center; width: 40px; height: 40px; border: 1px solid var(--c-border); border-radius: var(--r-md); }
  .brand__tag, .brand__zh small { display: block; }
}

.hero {
  background:
    linear-gradient(180deg, rgba(31,58,45,0.88), rgba(20,36,32,0.96)),
    radial-gradient(ellipse at top, #2E5E3E 0%, transparent 60%),
    var(--c-primary-d);
  color: white;
  padding-block: clamp(72px, 10vw, 144px);
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: repeating-linear-gradient(135deg, transparent 0, transparent 40px, rgba(201,169,97,0.025) 40px, rgba(201,169,97,0.025) 80px);
  pointer-events: none;
}
.hero__inner { position: relative; }
.hero__eyebrow { display: inline-flex; align-items: center; gap: var(--sp-3); color: var(--c-accent); margin-bottom: var(--sp-5); font-family: var(--f-en-sans); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
.hero__eyebrow::before, .hero__eyebrow::after { content: ''; width: 24px; height: 1px; background: var(--c-accent); opacity: 0.5; }
.hero__title {
  font-family: var(--f-en-sans);
  font-weight: 900;
  font-size: clamp(2.4rem, 6vw, 4.5rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: var(--sp-5);
  max-width: 18ch;
}
.hero__title em { font-style: italic; color: var(--c-accent); font-family: 'Mona Sans', var(--f-en-sans); font-weight: 800; }
.hero__sub { font-size: clamp(1.05rem, 1.4vw, 1.2rem); color: rgba(255,255,255,0.82); max-width: 60ch; line-height: 1.65; margin-bottom: var(--sp-7); }
.hero__sub strong { color: white; font-weight: 500; }
.hero__cta { display: flex; gap: var(--sp-4); flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--sp-2); padding: var(--sp-4) var(--sp-6); border-radius: var(--r-md); font-weight: 600; font-size: 0.9rem; letter-spacing: 0.02em; transition: all var(--t-fast); white-space: nowrap; }
.btn--primary { background: var(--c-cta); color: white; }
.btn--primary:hover { background: var(--c-cta-d); transform: translateY(-2px); box-shadow: var(--shadow-md); }
.btn--ghost { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.3); }
.btn--ghost:hover { background: rgba(255,255,255,0.08); border-color: white; }
.hero__badges { margin-top: var(--sp-8); display: flex; gap: var(--sp-6); flex-wrap: wrap; padding-top: var(--sp-6); border-top: 1px solid rgba(255,255,255,0.12); }
.hero__badge { display: flex; flex-direction: column; gap: var(--sp-1); }
.hero__badge .num { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--c-accent); line-height: 1; }
.hero__badge .label { font-size: 0.78rem; color: rgba(255,255,255,0.65); letter-spacing: 0.04em; }

.marquee {
  background: var(--c-primary-d);
  border-block: 1px solid rgba(201,169,97,.2);
  padding: 22px 0;
  overflow: hidden; position: relative;
}
.marquee::before, .marquee::after { content:''; position: absolute; top:0; bottom:0; width: 80px; z-index: 2; pointer-events: none; }
.marquee::before { left:0; background: linear-gradient(90deg, var(--c-primary-d), transparent); }
.marquee::after { right:0; background: linear-gradient(-90deg, var(--c-primary-d), transparent); }
.marquee__track { display: flex; gap: 64px; white-space: nowrap; animation: scroll-marquee 50s linear infinite; will-change: transform; }
.marquee__item {
  font-family: 'Mona Sans', var(--f-en-sans);
  font-style: italic; font-weight: 700;
  font-size: clamp(1.25rem, 2.2vw, 1.85rem);
  color: var(--c-accent);
  display: flex; align-items: center; gap: 64px;
  letter-spacing: -0.005em;
}
.marquee__item::after { content:'✦'; font-size:.5em; color: rgba(201,169,97,.5); font-style: normal; }
@keyframes scroll-marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
@media (prefers-reduced-motion: reduce) { .marquee__track { animation: none !important; } }

.trust { padding-block: clamp(48px, 6vw, 80px); background: var(--c-surface); border-bottom: 1px solid var(--c-border); }
.trust__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-7); }
.trust-card { display: flex; flex-direction: column; gap: var(--sp-4); padding: var(--sp-2); }
.trust-card__icon { width: 56px; height: 56px; border-radius: var(--r-md); background: rgba(31,58,45,0.06); display: grid; place-items: center; color: var(--c-primary); }
.trust-card h3 { color: var(--c-primary); }
.trust-card p { color: var(--c-text-mut); font-size: 0.95rem; }

.about__grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(40px, 6vw, 80px); align-items: center; }
@media (max-width: 880px) { .about__grid { grid-template-columns: 1fr; } }
.about__copy h2 { color: var(--c-primary); margin-bottom: var(--sp-5); }
.about__copy h2 em { font-style: italic; color: var(--c-accent-d); font-family: var(--f-en-serif); font-weight: 700; }
.about__copy p { margin-bottom: var(--sp-4); color: var(--c-text-mut); }
.about__copy p strong { color: var(--c-text); font-weight: 600; }

.stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--c-border); border-radius: var(--r-lg); overflow: hidden; border: 1px solid var(--c-border); }
.stat { background: var(--c-surface); padding: var(--sp-6) var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-2); }
.stat__num { font-family: var(--f-num); font-feature-settings: 'tnum' on; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: var(--c-primary); line-height: 1; letter-spacing: -0.02em; }
.stat__num sup { font-size: 0.5em; font-weight: 600; color: var(--c-accent-d); }
.stat__label { font-size: 0.85rem; color: var(--c-text-mut); letter-spacing: 0.02em; }

.spec-sheet { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
.spec-sheet__head { background: var(--c-primary); color: white; padding: var(--sp-5) var(--sp-6); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--sp-3); }
.spec-sheet__head .label { font-family: var(--f-en-sans); font-size: 0.7rem; letter-spacing: 0.18em; color: var(--c-accent); font-weight: 600; }
.spec-sheet__head .title { font-size: 1.05rem; font-weight: 700; }
.spec-sheet__head .meta { font-size: 0.8rem; color: rgba(255,255,255,0.7); }
.spec-sheet table { width: 100%; border-collapse: collapse; }
.spec-sheet td { padding: var(--sp-4) var(--sp-6); border-bottom: 1px solid var(--c-border); font-size: 0.95rem; }
.spec-sheet td:first-child { width: 38%; color: var(--c-text-mut); font-weight: 500; background: var(--c-bg-alt); }
.spec-sheet td:last-child { font-weight: 500; }
.spec-sheet tr:last-child td { border-bottom: none; }
.spec-sheet__foot { padding: var(--sp-4) var(--sp-6); font-size: 0.8rem; color: var(--c-text-soft); background: var(--c-bg-alt); border-top: 1px solid var(--c-border); }

.cert-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--sp-5); }
.cert { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: var(--sp-6); text-align: center; transition: all var(--t-mid); }
.cert:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.cert__seal { width: 80px; height: 80px; margin: 0 auto var(--sp-4); border-radius: 50%; display: grid; place-items: center; font-family: var(--f-en-serif); font-weight: 700; font-size: 1.25rem; letter-spacing: 0.04em; }
.cert--active .cert__seal { background: var(--c-trust); color: white; box-shadow: 0 0 0 4px rgba(46,125,50,0.12); }
.cert--pending .cert__seal { background: var(--c-bg-alt); color: var(--c-text-soft); border: 2px dashed var(--c-border); }
.cert h3 { margin-bottom: var(--sp-2); color: var(--c-primary); }
.cert p { font-size: 0.85rem; color: var(--c-text-mut); }
.cert__status { display: inline-block; margin-top: var(--sp-3); font-size: 0.7rem; padding: 2px var(--sp-3); border-radius: 100px; letter-spacing: 0.04em; font-weight: 600; }
.cert--active .cert__status { background: rgba(46,125,50,0.12); color: var(--c-trust); }
.cert--pending .cert__status { background: var(--c-bg-alt); color: var(--c-text-soft); }

.product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-5); }
.product { background: var(--c-surface); border-radius: var(--r-lg); overflow: hidden; border: 1px solid var(--c-border); display: flex; flex-direction: column; transition: all var(--t-mid); }
